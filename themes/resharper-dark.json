{
  "name": "ReSharper Dark Theme",
  "type": "dark",
  "tokenColors": [
    {
      "name": "keyword",
      "scope": [
        "constant.language",
        "entity.name.tag",
        "keyword",
        "keyword.operator.as",
        "keyword.operator.expression",
        "keyword.operator.filetest",
        "keyword.operator.logical",
        "keyword.operator.new",
        "keyword.operator.quantifier",
        "meta.separator",
        "punctuation.definition.block.tag",
        "punctuation.definition.bold",
        "punctuation.definition.italic",
        "punctuation.definition.list",
        "punctuation.definition.strikethrough",
        "punctuation.definition.table",
        "punctuation.separator.hash",
        "punctuation.separator.table",
        "storage",
        "support.function"
      ],
      "settings": {
        "foreground": "#569cd6"
      }
    },
    {
      "name": "class",
      "scope": [
        "entity.name.import",
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.delegate",
        "entity.name.type.namespace",
        "entity.other.inherited-class",
        "support.class",
        "support.other.namespace",
        "support.type.builtin",
        "support.type.object.module",
        "support.type.primitive",
        "variable.other.object",
        "variable.other.readwrite.alias"
      ],
      "settings": {
        "foreground": "#add8e6"
      }
    },
    {
      "name": "string",
      "scope": [
        "markup.fenced_code.block",
        "markup.inline.raw.string",
        "markup.quote",
        "markup.raw.block",
        "punctuation.definition.string",
        "string",
        "string.other.link.description.title"
      ],
      "settings": {
        "foreground": "#d69d85"
      }
    },
    {
      "name": "function",
      "scope": [
        "entity.name.function",
        "keyword.control.regexp-option",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "variable",
      "scope": [
        "entity.name.variable",
        "entity.name.variable.local",
        "entity.name.variable.parameter",
        "entity.other.attribute-name",
        "meta.property-value",
        "punctuation.definition.template-expression",
        "punctuation.definition.variable",
        "support.constant.property-value",
        "variable"
      ],
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "name": "escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#e07a00"
      }
    },
    {
      "name": "comment",
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#57a64a"
      }
    },
    {
      "name": "operator",
      "scope": [
        "keyword.operator",
        "meta.brace",
        "punctuation.accessor",
        "punctuation.curlybrace",
        "punctuation.definition.arguments",
        "punctuation.definition.array",
        "punctuation.definition.begin.bracket",
        "punctuation.definition.block",
        "punctuation.definition.dictionary",
        "punctuation.definition.end.bracket",
        "punctuation.definition.link",
        "punctuation.definition.metadata",
        "punctuation.definition.parameters",
        "punctuation.definition.tag",
        "punctuation.definition.typeparameters",
        "punctuation.parenthesis",
        "punctuation.section",
        "punctuation.separator",
        "punctuation.squarebracket",
        "punctuation.terminator",
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#dcdcdc"
      }
    },
    {
      "name": "constant",
      "scope": [
        "constant",
        "constant.language.import-export-all",
        "entity.name.variable.field",
        "heading",
        "markup.heading",
        "meta.object.member",
        "support.constant",
        "support.type.property-name",
        "support.type.vendored.property-name",
        "support.variable.property",
        "variable.other.object.property",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#ee82ee"
      }
    },
    {
      "name": "numeric",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "name": "regexp",
      "scope": [
        "keyword.control.anchor",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#e8bf6a"
      }
    },
    {
      "name": "command",
      "scope": [
        "entity.name.command",
        "support.function.builtin.shell"
      ],
      "settings": {
        "foreground": "#c57633"
      }
    },
    {
      "name": "link",
      "scope": [
        "meta.link",
        "punctuation.definition.link.description",
        "punctuation.definition.link.title",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#287bde"
      }
    },
    {
      "name": "link destination",
      "scope": [
        "markup.underline.link",
        "meta.image.inline",
        "meta.link.inline"
      ],
      "settings": {
        "foreground": "#00ffff"
      }
    }
  ],
